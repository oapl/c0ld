name = "c0ld-clan-api"
main = "c0ld-clan-api-worker.js"
compatibility_date = "2026-06-16"

[triggers]
crons = ["*/5 * * * *"]

[vars]
CLAN_NAME = "c0ld"
CURRENT_BATTLE_NAME = "auto"
AUTO_DETECT_BATTLE = "true"
ACTIVE_BATTLE_LOOKUP = "true"
# Optional overrides. Leave blank to use API metadata when present.
CURRENT_BATTLE_DISPLAY_NAME = ""
CURRENT_BATTLE_END_ISO = ""
SITE_ORIGINS = "https://oapl.github.io"
PUBLIC_CACHE_SECONDS = "30"
RETENTION_HOURS = "336"
ROBLOX_USERNAME_LOOKUPS = "true"
SUPABASE_URL = "https://YOUR-PROJECT.supabase.co"
INGEST_CLANS_LEADERBOARD = "true"
CLAN_RANK_TOP_N = "200"

# Set these with `wrangler secret put ...`
# SUPABASE_SERVICE_KEY
# INGEST_ADMIN_TOKEN
